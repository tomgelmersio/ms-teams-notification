{
  "name": "typescript-action",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript template action",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "pack": "ncc build lib/main.js -o dist",
    "all": "npm run build && npm run format && npm run pack"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/typescript-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "jdcargile",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.0",
    "@octokit/rest": "^22.0.1",
    "axios": "1.15.0",
    "moment-timezone": "^0.5.39-2022f"
  },
  "devDependencies": {
    "@types/jest": "^29.2.4",
    "@types/moment-timezone": "^0.5.30",
    "@types/node": "^16.11.7",
    "@typescript-eslint/parser": "^8.0.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.30.0",
    "eslint-plugin-github": "^5.0.2",
    "eslint-plugin-jest": "^29.0.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.3.1",
    "js-yaml": "^3.14.1",
    "prettier": "^2.8.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.0.0"
  }
}
